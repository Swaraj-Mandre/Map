# Copy this file to .env.local and fill it with real credentials.
# WARNING: Never commit real account credentials.

# Telegram API credentials (from https://my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# String session generated via scripts/telegram/generate_session.py
TELEGRAM_SESSION=

# Comma-separated channel usernames or t.me links
TELEGRAM_CHANNELS=https://t.me/osinttechnical,https://t.me/CITeam,https://t.me/ThirdEyeOSINTandAnalysis,https://t.me/weaponsandequipmentarchives,https://t.me/indopacificdiary

# Messages per channel per refresh
TELEGRAM_LIMIT=20

